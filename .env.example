# MiniClaude Configuration
# Copy this file to .env and fill in your values

# API Configuration
# MINICLAUDE_API_KEY=your-api-key-here
# MINICLAUDE_API_BASE_URL=https://api.anthropic.com
# MINICLAUDE_API_VERSION=2023-06-01
# MINICLAUDE_MODEL=claude-3-opus-20240229

# Logging
# MINICLAUDE_LOG_LEVEL=INFO
# MINICLAUDE_LOG_FILE=/path/to/mini-claude.log
